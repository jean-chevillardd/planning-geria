  db.run(sql, params);
  const id = db.exec('SELECT last_insert_rowid() as id')[0]?.values[0][0];
  persist();
  return { lastInsertRowid: id };
}

function transaction(fn) {
  db.run('BEGIN');
  try {
    fn();
    db.run('COMMIT');
    persist();
  } catch(e) {
    db.run('ROLLBACK');
    throw e;
  }
}

